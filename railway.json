{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "rootDirectory": "app"
  },
  "deploy": {
    "startCommand": "npm run start",
    "restartPolicyType": "ON_FAILURE",
    "env": {
      "NIXPACKS_NODE_VERSION": "22",
      "NIXPACKS_PKGS": "python3 gcc gnumake",
      "NODE_ENV": "production"
    }
  }
}
