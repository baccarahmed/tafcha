{
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile",
    "buildContext": "."
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 300
  },
  "database": {
    "postgreSQL": {
      "version": "15",
      "plan": "starter"
    }
  },
  "railway": {
    "description": "Tafchaa E-commerce Platform - Optimized Build",
    "repository": "",
    "orgId": ""
  },
  "environments": {
    "production": {
      "buildCommand": "npm ci --production=false --legacy-peer-deps && npx prisma generate && npm run build",
      "startCommand": "npm run server"
    }
  }
}